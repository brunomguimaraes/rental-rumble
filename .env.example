# Upstash Redis credentials for the daily-boss leaderboard.
# Create a free database at https://console.upstash.com (Redis) and copy the
# "REST API" URL + token here. On Vercel, add these as Project Environment
# Variables instead (Settings -> Environment Variables).
#
# For local development with `vercel dev`, copy this file to `.env.local`.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Secret used to sign run tokens (HMAC) so the server can guarantee a leaderboard
# submission came from a run it actually authorised — not a forged/replayed POST.
# Use a long random string (>= 16 chars), e.g. `openssl rand -base64 32`.
# Keep it private and NEVER expose it to the client bundle. When unset, run-token
# enforcement is OFF and the board falls back to sim-only verification.
LEADERBOARD_SECRET=
