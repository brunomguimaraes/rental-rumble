# Upstash Redis credentials for the daily-boss leaderboard.
# Create a free database at https://console.upstash.com (Redis) and copy the
# "REST API" URL + token here. On Vercel, add these as Project Environment
# Variables instead (Settings -> Environment Variables).
#
# For local development with `vercel dev`, copy this file to `.env.local`.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Secret used to sign run tokens (HMAC) so the server can guarantee a leaderboard
# submission came from a run it actually authorised — not a forged/replayed POST.
# Use a long random string (>= 16 chars), e.g. `openssl rand -base64 32`.
# Keep it private and NEVER expose it to the client bundle. When unset, run-token
# enforcement is OFF and the board falls back to sim-only verification.
LEADERBOARD_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL ACCOUNTS + PROGRESSION (everything below). The whole feature is
# opt-in: with none of these set, the account layer is simply disabled and the
# game + public boards work exactly as before. All of these have free tiers.
# ─────────────────────────────────────────────────────────────────────────────

# Turso (libSQL / SQLite) — holds accounts, the personal Pokédex and run history.
# Create a free DB at https://turso.tech, then grab its URL + an auth token
# (`turso db show <name> --url` and `turso db tokens create <name>`). For offline
# dev you can instead point at a local SQLite file (no token needed):
# TURSO_DATABASE_URL=file:local.db . Apply the schema once with `npm run db:setup`.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Secret used to sign the session cookie (HMAC). A long random string (>= 16
# chars), e.g. `openssl rand -base64 32`. Falls back to LEADERBOARD_SECRET when
# unset, so a board-enabled deploy gets working sessions for free.
AUTH_SECRET=

# Resend (https://resend.com) for verification + password-reset emails. Free
# tier: 3,000/month. EMAIL_FROM must be a verified sender (a domain you've added,
# or onboarding@resend.dev for testing). Without these, signups still work but no
# verification/reset email is sent.
RESEND_API_KEY=
EMAIL_FROM=

# Discord + Google OAuth apps. Register each, then set the OAuth redirect URI to
# `<APP_BASE_URL>/api/auth/oauth-callback` (e.g. http://localhost:3000/api/auth/oauth-callback
# for local `vercel dev`). Leave a provider's pair blank to disable just that one.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Absolute base URL of the deployment, used to build OAuth redirect URIs and the
# links in emails. Optional locally (derived from the request), but SET IT in
# production so those URLs are stable, e.g. https://your-game.vercel.app
APP_BASE_URL=
